<Window MinWidth="1050" MinHeight="600"
        x:Class="P01_ALBARRAN_VS_ENGRANAJES.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P01_ALBARRAN_VS_ENGRANAJES"
        mc:Ignorable="d"
        Title="CDEM - Calculador y Diseñador de Elementos de Máquina -Engranajes"  Height="450" Width="800" Icon="/Assets/Images/UI/Icon_Engrane.ico">

    <Grid Background="{StaticResource Azul9}">

        <Grid.RowDefinitions>

            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="*"/>
            <RowDefinition Height="15"></RowDefinition>

        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource Azul4}">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>

            </Grid.ColumnDefinitions>

            <Menu Grid.Column="0">
                <MenuItem Header=" ARCHIVO">
                    <MenuItem Header="Calculadora de Ecuaciones" Click="VentanaCalculadora_Click"></MenuItem>
                    <MenuItem Header="Guardar" Click="GuardarDatos_Click"></MenuItem>
                </MenuItem>
            </Menu>
            <!--
            <Menu Grid.Column="1">
                <MenuItem Header="  EXTRAS">
                    <MenuItem Header="CONVERSIÓN DE UNIDADES"></MenuItem>
                </MenuItem>
            </Menu>
                -->
            
            <Menu Grid.Column="3">
                <MenuItem Header="   AYUDA">
                    <MenuItem Header="ACERCA DE" Click="AbirAcercaDeView"></MenuItem>
                    <MenuItem Header="MANUAL" Click="AbrirManualView"></MenuItem>
                </MenuItem>
            </Menu>

        </Grid>

        <Grid Grid.Row="2">

            <Grid.ColumnDefinitions>

                <ColumnDefinition Width="200"></ColumnDefinition>
                <ColumnDefinition Width="25"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>

            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource Azul2}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"></RowDefinition>
                    <RowDefinition Height="20"></RowDefinition>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Margin="10,5,10,0" Background="{StaticResource Gris7}" FontSize="14" FontWeight="Bold" Text="  MÓDULOS DE CÁLCULO"></TextBlock>
                </Grid>
                
                <StackPanel Grid.Row="2" Margin="10">
                    <TreeView Background="{StaticResource Gris7}">
                        <TreeViewItem Header="Engranajes">
                            <TreeViewItem Header="Cilíndricos rectos">
                                <Button Width="60"
                                    Background="{StaticResource Gris8}" 
                                    BorderBrush="{StaticResource Gris9}"
                                    Name="ir"
                                    Click="ir_Click"    
                                    >Ir.....</Button>
                            </TreeViewItem>
                        </TreeViewItem>
                    </TreeView>
                </StackPanel>
                <Image Grid.Row="3"
                       Source="/Assets/Images/UI/Logo_UTN.png"
                       Margin="30"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Bottom" IsEnabled="False" Opacity="0.75" Visibility="Hidden"/>

            </Grid>


            <Grid Grid.Column="2" Name="Principal" Background="{StaticResource Azul10}">
                <ContentControl x:Name="windowsOperation"/>
            </Grid>

        </Grid>

        <Grid Grid.Row="3" Background="{StaticResource Gris9}">
            <Viewbox Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="  © 2025 Universidad Técnica del Norte. Todos los derechos reservados."
               TextAlignment="Center"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Foreground="Black"/>
            </Viewbox>
        </Grid>

    </Grid>
</Window>
