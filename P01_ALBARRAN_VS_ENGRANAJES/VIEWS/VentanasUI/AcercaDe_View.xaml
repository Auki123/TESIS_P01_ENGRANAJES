<Window x:Class="P01_ALBARRAN_VS_ENGRANAJES.VIEWS.VentanasUI.AcercaDe_View"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:P01_ALBARRAN_VS_ENGRANAJES.VIEWS.VentanasUI"
        mc:Ignorable="d"
        Icon="/Assets/Images/UI/Icon_Engrane.ico"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow" WindowStartupLocation="CenterScreen"
        Title="Acerca De CDEM" MinHeight="350" MaxHeight="350" MinWidth="400" MaxWidth="400"
        Background="{StaticResource Azul3}">
    
    <Grid Margin="5" Background="WhiteSmoke">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="{StaticResource Azul10}">
            <StackPanel>
                <Image Margin="10"
                Source="/Assets/Images/UI/LogoSistema.png"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top" Opacity="0.85">
                </Image>

                <TextBlock Text="CDEM_ V 1.0.1" FontWeight="Bold"
                       VerticalAlignment="Top"
                           Margin=" 10,0,0,0"></TextBlock>
                <TextBlock Text="Octubre 2025" FontWeight="Bold"
                       VerticalAlignment="Top" HorizontalAlignment="Center"
                       Height="21"></TextBlock>



            </StackPanel>
        </Grid>
        
        <Grid Grid.Column="1" Background="{StaticResource Azul10}">
            <Border BorderBrush="{StaticResource Azul9}" BorderThickness="1">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Autor :" Margin="20,20,0,0" FontSize="14" FontWeight="Bold"></TextBlock>
                        <TextBlock Text="Auki Albarrán" Margin="40,0,0,10" FontSize="14"></TextBlock>
                        <TextBlock Text="Norma base :" Margin="20,0,0,0" FontSize="14" FontWeight="Bold"></TextBlock>
                        <TextBlock Text="Adaptación AGMA" Margin="40,0,0,0" FontSize="14"></TextBlock>
                        <TextBlock Text="métrica." Margin="40,0,0,10" FontSize="14"></TextBlock>
                    </StackPanel>
                    
                    <Button Grid.Row="1" Height="25" Width="50" Content="OK" FontWeight="Bold"
                            Background="{StaticResource Gris10}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="10"
                            Click="OK"></Button>
                </Grid>
            </Border>
        </Grid>


    </Grid>
</Window>
