<UserControl x:Class="P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos._03_CalculoReaccionesVIEW"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin=" 20">
        <Grid.RowDefinitions>
            <RowDefinition Height="110"></RowDefinition>
            <RowDefinition Height="200"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="10" FontSize="14">    
                <Run Text="Cálculo de cargas, y Cinemática :" FontWeight="Bold"/>
            <LineBreak/>
                <Run Text="Un par de engranajes cilíndricos rectos al estar sometidas a una carga, su geometría hace que estas cargas afecten de dos posibles maneras: "/>
            <LineBreak/>
                <Run Text="  ➣ Radial "/>
            <LineBreak/>
                <Run Text="  ➣ Axial "/>
        </TextBlock>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
                <ColumnDefinition></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <StackPanel Margin="20" Background="{StaticResource Extra_light_Gray}">
                
                <StackPanel Orientation="Horizontal">
                    <Label Content="Potencia (HP):                                   " VerticalAlignment="Center"></Label>
                    <TextBox Width="70"
                             Height="20"
                             Margin="5"
                             PreviewTextInput="ControlEntradaTexBox"
                             Name="EntradaPotencia"
                             ></TextBox>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal">
                    <Label Content="Velocidad angular en Piñón (RPM):  " VerticalAlignment="Center"></Label>
                    <TextBox Width="70"
                             Height="20"
                             Margin="5"
                             PreviewTextInput="ControlEntradaTexBox"
                             Name="EntradaVangular"
                            ></TextBox>
                </StackPanel>

                <Button
                    Content="Calcular"
                    Margin="30"
                    Width="60"
                    Height="20"
                    HorizontalAlignment="Center"
                    Click="CalcularParámetrosDinámicos"
                    ></Button>
                
            </StackPanel>

            <DataGrid IsReadOnly="True" Grid.Column="1" Margin="20" Height="Auto" Name="MostrarCargasEnPinon" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Parámetros de Piñón" Binding="{Binding Key}" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*"></DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>

            <DataGrid IsReadOnly="True" Grid.Column="2" Margin="20" Height="Auto" Name="MostrarCargasEnCorona" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Parámetros de Corona" Binding="{Binding Key}" Width="*"></DataGridTextColumn>
                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*"></DataGridTextColumn>
                </DataGrid.Columns>

            </DataGrid>
            
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Grid.Row="3">
            
            <Button Click="Regresar_Click"
                Content="Recalcular geometría"
                Margin="0,0,10,0"
                Width="120"></Button>
            
            <Button 
                    Content="Continuar"
                    HorizontalAlignment="Right"
                    Width="60"
                    Click="ContinuarAFactoresK"
                ></Button>

        </StackPanel>

    </Grid>
</UserControl>
