<Window x:Class="P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos._04_01_CalcularKvModel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:scottplot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        xmlns:local="clr-namespace:P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos"
        mc:Ignorable="d"
        Title="Factor Kv" Height="450" Width="800" Background="{StaticResource Azul3}"
        ResizeMode="NoResize" WindowStyle="SingleBorderWindow" WindowStartupLocation="CenterScreen" 
        MaxHeight="500" MaxWidth="1010" MinHeight="500" MinWidth="1010"
        Icon="/Assets/Images/UI/Icon_Engrane.ico">

    <Grid Margin="10" Background="{StaticResource Azul8}">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition Height="10*"></RowDefinition>
            <RowDefinition Height="50"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Margin="5"
                   Text="Es un coeficiente que ajusta el cálculo de esfuerzos para considerar los efectos dinámicos como errores de fabricación, vibraciones, rigidez del sistema y velocidad de operación."
                   ></TextBlock>

        <Grid Grid.Row="1" Margin="10" Background="{StaticResource Azul10}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"></ColumnDefinition>
                <ColumnDefinition Width="200"></ColumnDefinition>
                <ColumnDefinition Width="250*"></ColumnDefinition>
                <ColumnDefinition Width="20"></ColumnDefinition>
            </Grid.ColumnDefinitions>


            <Image Margin="10"
                   Grid.Column="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                    Source="/Assets/Images/Tecnico/Engranaje_CilindricoRecto/E2_Esfuerzo_IndiceCalidad_SegunUso.png"
                    >
            </Image>

            <StackPanel Grid.Column="1">
                <Image Margin="10"
                       Source="/Assets/Images/Tecnico/Engranaje_CilindricoRecto/E2_Esfuerzo_IndiceCalidad_SegunVelocidad.png"
                       
                    >
                </Image>
                <TextBlock Text="Parámetros de entrada:"
                           HorizontalAlignment="Center"
                           Margin="10,3,10,3"
                           ></TextBlock>
                <StackPanel Margin="10,3,10,3" Orientation="Horizontal">
                    <TextBlock Text="Velocidad Vt:            "></TextBlock>
                    <TextBox x:Name="Velocidad_LineaPaso"
                             Height="20"
                             Width="60"
                             IsEnabled="False"
                        />
                </StackPanel>
                
                <StackPanel Margin="10,3,10,3" Orientation="Horizontal">
                    <TextBlock Text="Indice de Calidad:    "></TextBlock>
                    <TextBox Name="I_Qv_Value"
                             PreviewTextInput="ControlEntradaTexBox"
                             Height="20"
                            Width="60"
                        ></TextBox>
                </StackPanel>

                <StackPanel Margin="10,3,10,3" Orientation="Horizontal">
                    <Button Content="Calcular "
                            Click="CalcularKV"
                            Height="20"
                            Width="60"
                    ></Button>

                    <TextBlock Text="              ."></TextBlock>
                    
                    
                    <TextBox Name="Kv_Value"
                             Height="20"
                             Width="60"
                             IsEnabled="False"
                    ></TextBox>
                    
                </StackPanel>


            </StackPanel>


            <Grid Grid.Column="2" Margin="10">
                
                <scottplot:WpfPlot
                    Name="wpfPlot"
                    Background="White"
                    ></scottplot:WpfPlot>
                
            </Grid>

        </Grid>

    </Grid>
</Window>
