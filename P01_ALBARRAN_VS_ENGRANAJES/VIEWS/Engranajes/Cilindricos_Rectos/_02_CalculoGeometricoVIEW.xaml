<UserControl x:Class="P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos._02_CalculoGeometricoVIEW"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:P01_ALBARRAN_VS_ENGRANAJES.VIEWS.Engranajes.Cilindricos_Rectos"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Cursor="">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition  Height="*"></RowDefinition>
            <RowDefinition Height="20"></RowDefinition>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="10" FontSize="14">    
        <Run Text="Diseño Geométrico:" FontWeight="Bold"/>
        <LineBreak/>
            <Run Text="El método de diseño se basa en la selección de engranajes con el menor número de dientes posible, sin comprometer la funcionalidad, con el objetivo de evitar interferencias durante el engrane."/>
        <LineBreak/>
            <Run Text="Por lo tanto se requiere como dato de entrada, parámetros para el cálculo geométrico y evitar interferencia. "/>
        <LineBreak/>
            <Run Text="Si en número de dientes da como resultado un número decimal, debe considerar el modificar los diámetros de paso o en su defecto aumentar el número de dientes modificando el módulo."/>
        <LineBreak/>
            <Run Text="También debe considerar que la relación de contacto debe ser mayor a 1.4"></Run>
        </TextBlock>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">

                <WrapPanel Margin="10">
                    <TextBlock Text="    Diámetro de paso del Piñón (mm):       " FontSize="14"></TextBlock>
                    <TextBox
                    Name="d_pBox"
                    Width="80" HorizontalAlignment="Right"
                    Height="20"
                    PreviewTextInput="ControlEntradaTexBox"
            ></TextBox>
                </WrapPanel>

                <WrapPanel Margin="10">
                    <TextBlock Text="    Diámetro de paso de Corona (mm):     " FontSize="14"></TextBlock>
                    <TextBox
                        Name="d_gBox"
                        Width="80" HorizontalAlignment="Right"
                        Height="20"
                        PreviewTextInput="ControlEntradaTexBox"
                ></TextBox>
                </WrapPanel>

                <WrapPanel Margin="10">
                    <TextBlock Text="    Ángulo de presión (°):                           " FontSize="14"></TextBlock>
                    <ComboBox Width="80" IsEditable="False" Name="presure_angleBox" HorizontalAlignment="Right" Height="20">
                        <ComboBoxItem Content="20"></ComboBoxItem>
                        <ComboBoxItem Content="25"></ComboBoxItem>
                    </ComboBox>
                </WrapPanel>

                <Button Content="Calcular"
                Name="Calcular_Geometria"
                Height="20"
                Width="70"
                HorizontalAlignment="Center"
                Margin="10"
                Click="CalcularGeometria"></Button>


            </StackPanel>


            <DataGrid Grid.Column="1" 
              AutoGenerateColumns="False"
              Name="ContenidoGeometricoDataGrid"
              IsReadOnly="True"
              
              Margin="30,10,30,50" Background="{StaticResource sea-green}"
              Height="Auto"
              Width="300"
              VerticalAlignment="Top"
              HorizontalAlignment="Center"
              >
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Propiedad Geométrica" Binding="{Binding Key}" Width="1.7*"></DataGridTextColumn>
                    <DataGridTextColumn Header="Valor" Binding="{Binding Value}" Width="*"></DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>


        </Grid>

        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right">

            <Button Click="Regresar_Click"
                Content="Regresar "
                Width="80"
                Margin="0,0,10,0"
                ></Button>
            <Button
                Grid.Row="2"
                Content="Continuar"
                Height="20"
                Width="80"
                Click="Continuar"
            ></Button>

        </StackPanel>

    </Grid>



</UserControl>
